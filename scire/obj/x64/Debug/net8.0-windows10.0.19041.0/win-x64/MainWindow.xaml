<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="scire.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:scire"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
	Title="scire">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

	<Grid Padding="10" Background="#2c2d33">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<!-- Titel -->
			<RowDefinition Height="Auto"/>
			<!-- Section Titel -->
			<RowDefinition Height="*"/>
			<!-- Inhoud -->
			<RowDefinition Height="auto"/>
			<!-- add button -->
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="420px"/>
			<!-- Questions invoer kolom -->
			<ColumnDefinition Width="420px"/>
			<!-- Answers invoer kolom -->
			<ColumnDefinition Width="420px"/>
			<!-- Questions result kolom -->
			<ColumnDefinition Width="420px"/>
			<!-- Answers result kolom -->
		</Grid.ColumnDefinitions>

		<!-- Titel bovenaan, over beide kolommen -->
		<TextBlock Text="scire." FontSize="24" FontWeight="Bold" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,20"/>

		<!-- Titel invoer, over beide kolommen -->
		<TextBlock Text="input." FontSize="24" FontWeight="Bold" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,20"/>

		<!-- Titel output, over beide kolommen -->
		<TextBlock Text="saved input." FontSize="24" FontWeight="Bold" Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,0,0,20"/>

		<!-- Linkerkolom invoer: Questions -->
		<Border Grid.Row="2" Grid.Column="0" CornerRadius="10" Background="#202db3" Margin="0,0,10,0">
			<StackPanel Background="#202db3">
				<TextBlock Text="Questions Input:" Padding="10" FontWeight="SemiBold" Margin="0,0,0,5"/>
				<ListBox Width="auto" Background="red">
					<TextBox x:ConnectionId='6' Name="QuestionsInput" Height="30" Width="260px"/>
				</ListBox>
			</StackPanel>
		</Border>

		<!-- Linkerkolom invoer: Answers -->
		<Border Grid.Row="2" Grid.Column="1" CornerRadius="10" Background="#202db3" Margin="0,0,10,0">
			<StackPanel Background="#202db3">
				<TextBlock Text="Answers Input:" Padding="10" FontWeight="SemiBold" Margin="0,0,0,5"/>
				<ListBox Width="auto">
					<TextBox x:ConnectionId='5' Name="AnswersInput" Height="30" Width="260px"/>
				</ListBox>
			</StackPanel>
		</Border>

		<!-- Linkerkolom result: Questions -->
		<Border Grid.Row="2" Grid.RowSpan="2" Grid.Column="2" CornerRadius="10" Background="#202db3" Margin="0,0,10,0">
			<StackPanel Background="#202db3">
				<TextBlock Text="Questions Input:" Padding="10" FontWeight="SemiBold" Margin="0,0,0,5"/>
				<StackPanel x:ConnectionId='4' x:Name="QuestionsResult" Width="auto" Background="red"/>
			</StackPanel>
		</Border>

		<!-- Linkerkolom result: Answers -->
		<Border Grid.Row="2" Grid.RowSpan="2" Grid.Column="3" CornerRadius="10" Background="#202db3" Margin="0,0,10,0">
			<StackPanel Background="#202db3">
				<TextBlock Text="Answers Input:" Padding="10" FontWeight="SemiBold" Margin="0,0,0,5"/>
				<StackPanel x:ConnectionId='3' Background="red" x:Name="AnswersResult" Width="auto"/>
			</StackPanel>
		</Border>
		
		<Button x:ConnectionId='2' Content="Add Question"                           Grid.Row="3" Grid.ColumnSpan="2" Width="840px"/>
	</Grid>
</Window>

